   "source": [
    "from threading import Thread\n",
    "import time\n",
    "class myThread(Thread):\n",
    "    def run(self):\n",
    "        for i in range(10):\n",
    "            time.sleep(1)\n",
    "            print(\"starting thread\",i)\n",
    "t1=myThread()\n",
    "t2=myThread()\n",
    "t1.start()\n",
    "t2.start()\n",
    "t1.join()\n",
    "t2.join()\n",
    "print(\"main thread\")"
   ]
  },
